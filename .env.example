# =========================
# Application
# =========================
APP_NAME="Voice Diagnostic Agent"
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_PUBLIC_URL=https://your-ngrok-or-public-host.example.com
LOG_LEVEL=INFO

# =========================
# Database
# =========================
# For docker-compose use: postgresql+asyncpg://postgres:postgres@db:5432/voice_ai
# For local SQLite use:   sqlite+aiosqlite:///./data/voice_ai.db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/voice_ai
DATABASE_ECHO=false

# =========================
# OpenAI
# =========================
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17
OPENAI_VISION_MODEL=gpt-4o
OPENAI_TTS_VOICE=alloy

# =========================
# Twilio
# =========================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+15555555555

# =========================
# Email (SMTP)
# =========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@voicediagnostic.example.com
SMTP_FROM_NAME="Voice Diagnostic"
SMTP_USE_TLS=true

# =========================
# Upload
# =========================
UPLOAD_DIR=./uploads
UPLOAD_LINK_TTL_HOURS=24
UPLOAD_MAX_BYTES=10485760

# =========================
# Business
# =========================
BUSINESS_TIMEZONE=America/Chicago
SUPPORTED_APPLIANCES=washer,dryer,refrigerator,dishwasher,oven,hvac,microwave
